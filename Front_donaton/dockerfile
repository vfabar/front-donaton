# --- ETAPA 1: Compilación de la aplicación ---
FROM node:20-alpine AS build

WORKDIR /app

# Copiamos archivos de empaquetado
COPY package*.json ./

# Instalamos las dependencias base
RUN npm install

# Aseguramos que Axios esté instalado explícitamente en el entorno de Docker
RUN npm install axios

# Copiamos el resto del código del frontend
COPY . .

# Compilamos con Vite (Esto generará la carpeta /app/dist)
RUN npm run build

# --- ETAPA 2: Servidor de producción ligero con Nginx ---
FROM nginx:1.25-alpine

# Copiamos el resultado de Vite a la carpeta pública de Nginx
COPY --from=build /app/dist /usr/share/nginx/html

# Nginx internamente corre en el puerto 80 dentro del contenedor
EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]